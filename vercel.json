{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/event/(?<slug>[^/]+)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|crawl|spider|facebookexternalhit|slack|discord|twitterbot|linkedin|whatsapp|opengraph).*"
        }
      ],
      "dest": "/api/og-page?slug=$slug"
    },
    {
      "src": "/share/(?<slug>[^/]+)",
      "dest": "/share/$slug/index.html"
    },
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/event/(?<slug>[^/]+)",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
